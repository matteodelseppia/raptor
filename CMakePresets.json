{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 28, "patch": 0 },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },

    {
      "name": "gcc-debug",
      "inherits": "base",
      "displayName": "GCC 16 — Debug",
      "environment": { "CC": "gcc-16", "CXX": "g++-16" },
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "gcc-release",
      "inherits": "base",
      "displayName": "GCC 16 — Release",
      "environment": { "CC": "gcc-16", "CXX": "g++-16" },
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },

    {
      "name": "clang-debug",
      "inherits": "base",
      "displayName": "Clang 22 — Debug",
      "environment": { "CC": "clang-22", "CXX": "clang++-22" },
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "clang-release",
      "inherits": "base",
      "displayName": "Clang 22 — Release",
      "environment": { "CC": "clang-22", "CXX": "clang++-22" },
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },

    {
      "name": "appleclang-debug",
      "inherits": "base",
      "displayName": "Apple Clang — Debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "appleclang-release",
      "inherits": "base",
      "displayName": "Apple Clang — Release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },

    {
      "name": "msvc-debug",
      "inherits": "base",
      "displayName": "MSVC — Debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      }
    },
    {
      "name": "msvc-release",
      "inherits": "base",
      "displayName": "MSVC — Release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      }
    },

    {
      "name": "dev",
      "inherits": "appleclang-debug",
      "displayName": "Dev — ASan + UBSan (Apple Clang Debug)",
      "cacheVariables": {
        "RAPTOR_SANITIZE": "ON"
      }
    }
  ],

  "buildPresets": [
    { "name": "gcc-debug",        "configurePreset": "gcc-debug" },
    { "name": "gcc-release",      "configurePreset": "gcc-release" },
    { "name": "clang-debug",      "configurePreset": "clang-debug" },
    { "name": "clang-release",    "configurePreset": "clang-release" },
    { "name": "appleclang-debug", "configurePreset": "appleclang-debug" },
    { "name": "appleclang-release","configurePreset": "appleclang-release" },
    { "name": "msvc-debug",       "configurePreset": "msvc-debug" },
    { "name": "msvc-release",     "configurePreset": "msvc-release" },
    { "name": "dev",              "configurePreset": "dev" }
  ],

  "testPresets": [
    {
      "name": "gcc-debug",
      "configurePreset": "gcc-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "gcc-release",
      "configurePreset": "gcc-release",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "clang-debug",
      "configurePreset": "clang-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "clang-release",
      "configurePreset": "clang-release",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "appleclang-debug",
      "configurePreset": "appleclang-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "appleclang-release",
      "configurePreset": "appleclang-release",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "msvc-debug",
      "configurePreset": "msvc-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "msvc-release",
      "configurePreset": "msvc-release",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": { "outputOnFailure": true }
    }
  ]
}
