{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 28, "patch": 0 },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },

    {
      "name": "gcc-debug",
      "inherits": "base",
      "displayName": "GCC 16 — Debug",
      "environment": { "CC": "gcc-16", "CXX": "g++-16" },
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "gcc-release",
      "inherits": "base",
      "displayName": "GCC 16 — Release",
      "environment": { "CC": "gcc-16", "CXX": "g++-16" },
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },

    {
      "name": "clang-debug",
      "inherits": "base",
      "displayName": "Clang 22 — Debug",
      "environment": { "CC": "clang-22", "CXX": "clang++-22" },
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "clang-release",
      "inherits": "base",
      "displayName": "Clang 22 — Release",
      "environment": { "CC": "clang-22", "CXX": "clang++-22" },
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },

    {
      "name": "appleclang-debug",
      "inherits": "base",
      "displayName": "Apple Clang — Debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "appleclang-release",
      "inherits": "base",
      "displayName": "Apple Clang — Release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },

    {
      "name": "msvc-debug",
      "inherits": "base",
      "displayName": "MSVC — Debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      }
    },
    {
      "name": "msvc-release",
      "inherits": "base",
      "displayName": "MSVC — Release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      }
    },

    {
      "name": "windows-clang-debug",
      "inherits": "base",
      "displayName": "Windows Clang (LLVM) — Debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "windows-clang-release",
      "inherits": "base",
      "displayName": "Windows Clang (LLVM) — Release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },

    {
      "name": "macos-homebrew-clang-debug",
      "inherits": "base",
      "displayName": "macOS Homebrew LLVM Clang — Debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm/bin/clang",
        "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++"
      }
    },
    {
      "name": "macos-homebrew-clang-release",
      "inherits": "base",
      "displayName": "macOS Homebrew LLVM Clang — Release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm/bin/clang",
        "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++"
      }
    },

    {
      "name": "macos-gcc-debug",
      "inherits": "base",
      "displayName": "macOS Homebrew GCC — Debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "gcc-14",
        "CMAKE_CXX_COMPILER": "g++-14"
      }
    },
    {
      "name": "macos-gcc-release",
      "inherits": "base",
      "displayName": "macOS Homebrew GCC — Release",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER": "gcc-14",
        "CMAKE_CXX_COMPILER": "g++-14"
      }
    },

    {
      "name": "dev",
      "inherits": "appleclang-debug",
      "displayName": "Dev — ASan + UBSan (Apple Clang Debug)",
      "cacheVariables": {
        "RAPTOR_SANITIZE": "ON"
      }
    }
  ],

  "buildPresets": [
    { "name": "gcc-debug",                    "configurePreset": "gcc-debug" },
    { "name": "gcc-release",                  "configurePreset": "gcc-release" },
    { "name": "clang-debug",                  "configurePreset": "clang-debug" },
    { "name": "clang-release",                "configurePreset": "clang-release" },
    { "name": "appleclang-debug",             "configurePreset": "appleclang-debug" },
    { "name": "appleclang-release",           "configurePreset": "appleclang-release" },
    { "name": "msvc-debug",                   "configurePreset": "msvc-debug" },
    { "name": "msvc-release",                 "configurePreset": "msvc-release" },
    { "name": "windows-clang-debug",          "configurePreset": "windows-clang-debug" },
    { "name": "windows-clang-release",        "configurePreset": "windows-clang-release" },
    { "name": "macos-homebrew-clang-debug",   "configurePreset": "macos-homebrew-clang-debug" },
    { "name": "macos-homebrew-clang-release", "configurePreset": "macos-homebrew-clang-release" },
    { "name": "macos-gcc-debug",              "configurePreset": "macos-gcc-debug" },
    { "name": "macos-gcc-release",            "configurePreset": "macos-gcc-release" },
    { "name": "dev",                          "configurePreset": "dev" }
  ],

  "testPresets": [
    { "name": "gcc-debug",                    "configurePreset": "gcc-debug",                    "output": { "outputOnFailure": true } },
    { "name": "gcc-release",                  "configurePreset": "gcc-release",                  "output": { "outputOnFailure": true } },
    { "name": "clang-debug",                  "configurePreset": "clang-debug",                  "output": { "outputOnFailure": true } },
    { "name": "clang-release",                "configurePreset": "clang-release",                "output": { "outputOnFailure": true } },
    { "name": "appleclang-debug",             "configurePreset": "appleclang-debug",             "output": { "outputOnFailure": true } },
    { "name": "appleclang-release",           "configurePreset": "appleclang-release",           "output": { "outputOnFailure": true } },
    { "name": "msvc-debug",                   "configurePreset": "msvc-debug",                   "output": { "outputOnFailure": true } },
    { "name": "msvc-release",                 "configurePreset": "msvc-release",                 "output": { "outputOnFailure": true } },
    { "name": "windows-clang-debug",          "configurePreset": "windows-clang-debug",          "output": { "outputOnFailure": true } },
    { "name": "windows-clang-release",        "configurePreset": "windows-clang-release",        "output": { "outputOnFailure": true } },
    { "name": "macos-homebrew-clang-debug",   "configurePreset": "macos-homebrew-clang-debug",   "output": { "outputOnFailure": true } },
    { "name": "macos-homebrew-clang-release", "configurePreset": "macos-homebrew-clang-release", "output": { "outputOnFailure": true } },
    { "name": "macos-gcc-debug",              "configurePreset": "macos-gcc-debug",              "output": { "outputOnFailure": true } },
    { "name": "macos-gcc-release",            "configurePreset": "macos-gcc-release",            "output": { "outputOnFailure": true } },
    { "name": "dev",                          "configurePreset": "dev",                          "output": { "outputOnFailure": true } }
  ]
}
